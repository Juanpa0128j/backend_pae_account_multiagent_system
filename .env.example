# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- LLM Providers -----------------------------------------------------------

# Primary: OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-nano

# Fallback 1: Gemini (required)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Fallback 2: Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-20b

# --- Embeddings & Reranker (HuggingFace Inference API) ----------------------
HUGGINGFACE_API_KEY=your-huggingface-api-key

# --- PDF Parsing (LlamaCloud) ------------------------------------------------
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key

# --- Database (Supabase PostgreSQL) ------------------------------------------
DATABASE_URL=postgresql://pae:pae@localhost:5433/pae

# --- App Config --------------------------------------------------------------
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# LangSmith (observability / tracing)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=PAE Agentes
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=PAE Agentes

# --- Supabase Auth --- JWT Secret -------------------------------------------
# Found at: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
SUPABASE_URL=your-supabase-url-here
# --- Inngest (durable workflows) ---------------------------------------------
# Only needed when WORKFLOW_ENGINE=inngest. Default engine is inline.
WORKFLOW_ENGINE=inline
INNGEST_APP_ID=pae-backend
INNGEST_EVENT_KEY=evt-your-event-key
INNGEST_SIGNING_KEY=signkey-test-your-key
INNGEST_DEV=true
# Set to true when testing locally via ngrok + Inngest Cloud (overrides APP_ENV-based detection)
INNGEST_IS_PRODUCTION=
INNGEST_CONCURRENCY_PER_NIT=5
INNGEST_OPENAI_THROTTLE_RPM=400
