# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- LLM Providers -----------------------------------------------------------
# Primary: Gemini (required)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Fallback 1: OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-nano

# Fallback 2: Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-20b

# --- Embeddings & Reranker (HuggingFace Inference API) ----------------------
HUGGINGFACE_API_KEY=your-huggingface-api-key

# --- PDF Parsing (LlamaCloud) ------------------------------------------------
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key

# --- Database (Supabase PostgreSQL) ------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- App Config --------------------------------------------------------------
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# LangSmith (observability / tracing)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=PAE Agentes
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=PAE Agentes

# --- Supabase Auth --- JWT Secret -------------------------------------------
# Found at: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# --- Hatchet workflow engine (self-hosted) -----------------------------------
# Set HATCHET_ENABLED=true to route pipelines through Hatchet instead of BackgroundTasks
HATCHET_ENABLED=false
# Generate token via: docker exec pae-hatchet-engine /hatchet/hatchet-admin token create --name pae-worker --tenant-id <tenant-id>
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_TLS_STRATEGY=none
